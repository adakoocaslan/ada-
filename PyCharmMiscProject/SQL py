# Bellek üzerinde geçici bir veritabanı oluşturalım
conn = sqlite3.connect(':memory:')
cursor = conn.cursor()

# 1. Tabloyu Oluşturalım
cursor.execute('''
CREATE TABLE Kitaplar (
    KitapID INT PRIMARY KEY,
    KitapAd TEXT,
    Yazar TEXT,
    YayinYili INT
)
''')

# 2. Veri Ekleyelim
cursor.execute("INSERT INTO Kitaplar VALUES (1, 'Nutuk', 'Atatürk', 1927)")
cursor.execute("INSERT INTO Kitaplar VALUES (2, 'Çalıkuşu', 'R. Nuri Güntekin', 1922)")

# 3. Sorgulayalım ve Çıktıyı Görelim
print("--- Kütüphane Kitap Listesi ---")
cursor.execute("SELECT * FROM Kitaplar")
for row in cursor.fetchall():
    print(row)

